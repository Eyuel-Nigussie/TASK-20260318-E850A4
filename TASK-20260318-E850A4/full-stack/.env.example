# Optional host port overrides (defaults shown)
FRONTEND_PORT=15173
BACKEND_PORT=18000
POSTGRES_PORT=15432

# Backend runtime configuration
APP_ENV=production
DATABASE_URL=postgresql+psycopg2://platform_user:platform_pass@postgres:5432/platform_db
JWT_ACCESS_SECRET=access_secret_change_in_prod
JWT_REFRESH_SECRET=refresh_secret_change_in_prod
CORS_ORIGINS=http://localhost:15173
